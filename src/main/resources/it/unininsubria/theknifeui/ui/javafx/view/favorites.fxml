<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="theknife.ui.javafx.FavoritesController">

    <top>
        <Label text="I miei preferiti"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 10 10 10 10;"/>
    </top>

    <center>
        <TableView fx:id="tabellaPreferiti">
            <columns>
                <TableColumn fx:id="colonnaRistorante" text="Nome ristorante" prefWidth="180"/>
                <TableColumn fx:id="colonnaLuogo" text="Luogo" prefWidth="450"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <Label fx:id="etichettaVuota"
               text="Non hai ancora aggiunto ristoranti ai preferiti."
               style="-fx-text-fill: #6b7280; -fx-padding: 5 10 10 10;"/>
    </bottom>
</BorderPane>