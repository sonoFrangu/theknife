<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="theknife.ui.javafx.RestaurantDetailsController"
      stylesheets="@style.css"
      styleClass="details-root"
      spacing="12"
      prefHeight="700">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox spacing="10" styleClass="details-header">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="etichettaNome" styleClass="restaurant-name"/>

            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="📍" styleClass="emoticon"/>
                <Label fx:id="etichettaIndirizzo" styleClass="details-line"/>
            </HBox>

            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="🏙" styleClass="emoticon"/>
                <Label fx:id="etichettaCitta" styleClass="details-line"/>
            </HBox>
        </VBox>

        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Button fx:id="bottoneApriMaps"
                    text="Apri in Maps"
                    onAction="#onApriMaps"
                    styleClass="details-fav-btn"/>
            <Button fx:id="bottonePreferiti"
                    text="Aggiungi ai preferiti"
                    onAction="#onAggiungiAiPreferiti"
                    styleClass="details-fav-btn"/>
        </HBox>
    </HBox>

    <GridPane hgap="12" vgap="6" styleClass="details-info-panel">
        <columnConstraints>
            <ColumnConstraints percentWidth="35"/> <ColumnConstraints percentWidth="65"/>
        </columnConstraints>
        <children>
            <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="0" GridPane.columnIndex="0">
                <Label text="💰" styleClass="emoticon"/>
                <Label text="Prezzo medio:" styleClass="details-label"/>
            </HBox>

            <Label fx:id="valorePrezzo" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="details-value"/>

            <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="1" GridPane.columnIndex="0">
                <Label text="🍽" styleClass="emoticon"/>
                <Label text="Cucina:" styleClass="details-label"/>
            </HBox>
            <Label fx:id="valoreCucina" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="details-value"/>

            <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="2" GridPane.columnIndex="0">
                <Label text="🚚" styleClass="emoticon"/>
                <Label text="Consegna:" styleClass="details-label"/>
            </HBox>
            <Label fx:id="valoreConsegna" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="details-value"/>

            <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="3" GridPane.columnIndex="0">
                <Label text="📅" styleClass="emoticon"/>
                <Label text="Prenotazione:" styleClass="details-label"/>
            </HBox>
            <Label fx:id="valorePrenotazione" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="details-value"/>

            <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="4" GridPane.columnIndex="0">
                <Label text="📞" styleClass="emoticon"/>
                <Label text="Telefono:" styleClass="details-label"/>
            </HBox>
            <Label fx:id="valoreTelefono" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="details-value"/>

            <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="5" GridPane.columnIndex="0">
                <Label text="⭐" styleClass="emoticon"/>
                <Label text="Stelle Michelin:" styleClass="details-label"/>
            </HBox>
            <Label fx:id="valoreStelle" GridPane.rowIndex="5" GridPane.columnIndex="1" styleClass="details-value"/>

            <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="6" GridPane.columnIndex="0">
                <Label text="🌐" styleClass="emoticon"/>
                <Label text="Sito web:" styleClass="details-label"/>
            </HBox>
            <Hyperlink fx:id="linkSitoWeb" GridPane.rowIndex="6" GridPane.columnIndex="1" styleClass="details-link"/>
        </children>
    </GridPane>

    <Label text="Sito Web del ristorante" styleClass="details-section-title"/>

    <WebView fx:id="vistaSito"
             prefWidth="680.0"
             prefHeight="450.0"
             minHeight="280.0">
        <styleClass>
            <String fx:value="details-map"/>
        </styleClass>
    </WebView>

    <HBox spacing="10">
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="Chiudi"
                onAction="#onChiudi"
                styleClass="footer-button"/>
    </HBox>
</VBox>