<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="theknife.ui.javafx.LoginController"
            stylesheets="@style.css"
            styleClass="app-root"
            prefWidth="350" prefHeight="280">

    <center>
        <VBox alignment="TOP_LEFT" spacing="15" style="-fx-background-color: white;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Accedi" styleClass="section-title"/>

            <Separator />

            <VBox spacing="5">
                <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                <TextField fx:id="campoUsername" promptText="Inserisci username"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                <PasswordField fx:id="campoPassword" promptText="Inserisci password"/>
            </VBox>

            <Label fx:id="etichettaErrore" textFill="red" wrapText="true"/>

            <Pane VBox.vgrow="ALWAYS" />
            <Separator />

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Ospite"
                        onAction="#onGuest"
                        styleClass="footer-button"
                        style="-fx-background-color: #95a5a6;"/>

                <Button text="Accedi"
                        onAction="#onLogin"
                        styleClass="footer-button"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>