<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="theknife.ui.javafx.MyRestaurantsController">
    <top>
        <Label text="I miei ristoranti"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 10 10 10 10;"/>
    </top>
    <center>
        <TableView fx:id="tabellaRistoranti">
            <columns>
                <TableColumn fx:id="colonnaNome" text="Nome" prefWidth="180"/>
                <TableColumn fx:id="colonnaCitta" text="Città" prefWidth="120"/>
                <TableColumn fx:id="colonnaIndirizzo" text="Indirizzo" prefWidth="180"/>
                <TableColumn fx:id="colonnaCucina" text="Cucina" prefWidth="120"/>
                <TableColumn fx:id="colonnaStelle" text="Valutazione media" prefWidth="120"/>
                <TableColumn fx:id="colonnaRecensioni" text="Numero recensioni" prefWidth="120"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <Label fx:id="etichettaVuota"
               text="Non hai ancora inserito ristoranti."
               style="-fx-text-fill: #6b7280; -fx-padding: 8 10 8 10;"/>
    </bottom>
</BorderPane>